# ── WAHA connectivity ─────────────────────────────────────────────────────────
# URL of your running WAHA instance.
WAHA_BASE_URL=http://localhost:3000

# API key set in WAHA (WAHA_API_KEY env var in your WAHA docker-compose, or
# visible in the WAHA Dashboard → top-right menu → "API Key").
WAHA_API_KEY=your_waha_api_key_here

# ── WhatsApp sessions ─────────────────────────────────────────────────────────
# Name of the session linked to the phone you want to monitor for deletions.
# You will create this session in the WAHA Dashboard and scan its QR code.
#
# WAHA Core (free) only supports ONE session per instance. Set
# WAHA_LISTEN_SESSION and WAHA_NOTIFY_SESSION to the SAME value so a single
# WhatsApp account both is monitored and sends its own deletion alerts.
WAHA_LISTEN_SESSION=default

# Name of the session used to SEND notifications.
# On WAHA Core (free), this must equal WAHA_LISTEN_SESSION (see above).
# On WAHA Plus/Pro you may use a second dedicated session/account instead.
WAHA_NOTIFY_SESSION=default

# ── Notification target ───────────────────────────────────────────────────────
# JID that receives deletion alerts. Recommended: your own WhatsApp account's
# JID (the "Message Yourself" self-chat) so alerts stay private to you, no
# matter which group/DM the deleted message came from — e.g. 972501234567@c.us.
# Alternatively, use a WhatsApp GROUP JID (ends in "@g.us") — find it via:
#   GET http://localhost:3000/api/{WAHA_LISTEN_SESSION}/groups
NOTIFY_GROUP_ID=YOUR_JID@c.us

# ── Media attachments in notifications ────────────────────────────────────────
# false (default) = text-only notifications for everything, including deleted
#   images/files (described in text, not attached). Required on WAHA Core (free)
#   since sendImage/sendFile are Plus/Pro-only endpoints.
# true = attach the actual deleted image/file (requires WAHA Plus/Pro).
SEND_MEDIA_ATTACHMENTS=false

# ── Bot webhook URL (required for setup.sh) ───────────────────────────────────
# The URL that WAHA uses to reach THIS bot.
# Use the machine's LAN/public IP (NOT localhost — WAHA makes outbound calls).
# Example on the same server: http://192.168.1.10:8001
# Example in same Docker network: http://bot:8000
BOT_WEBHOOK_URL=http://YOUR_SERVER_IP:8001

# ── Storage ──────────────────────────────────────────────────────────────────
# How many days to keep downloaded media files before cleanup.
DAYS_TO_SAVE_FILES=7

# Local paths (used inside Docker via volume — usually no need to change).
MEDIA_DIR=/data/media
DB_PATH=/data/bot.db

# ── Deduplication ─────────────────────────────────────────────────────────────
# Prevents duplicate notifications if WAHA retries the same webhook call.
WEBHOOK_DEDUP_ENABLED=true

# ── Logging ──────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Admin panel (optional) ────────────────────────────────────────────────────
# Leave blank to disable the admin panel at /admin/.
#
# Generate a bcrypt hash of your chosen password:
#   python3 -c "from passlib.context import CryptContext; print(CryptContext(schemes=['bcrypt']).hash('yourpassword'))"
ADMIN_PASSWORD_HASH=

# Random secret for signing session cookies:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ── Wet-test variables (only needed when running wet_tests/) ──────────────────
# WET_TEST_SENDER_SESSION=sender
# WET_TEST_LISTENER_JID=972501234567@c.us
